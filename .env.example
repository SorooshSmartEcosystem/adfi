# .env.example
# Copy to .env.local and fill in real values.
# Never commit .env.local to git.

# =============================================================
# SUPABASE (database + auth + storage)
# =============================================================
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
SUPABASE_URL="https://[PROJECT].supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Client-facing mirrors (safe to expose — RLS enforces security)
NEXT_PUBLIC_SUPABASE_URL="${SUPABASE_URL}"
NEXT_PUBLIC_SUPABASE_ANON_KEY="${SUPABASE_ANON_KEY}"
EXPO_PUBLIC_SUPABASE_URL="${SUPABASE_URL}"
EXPO_PUBLIC_SUPABASE_ANON_KEY="${SUPABASE_ANON_KEY}"

# =============================================================
# STRIPE (payments + billing)
# =============================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Price IDs (create four products in Stripe dashboard first):
#   SOLO    $29/mo  · 1 business · 60 credits  · DM-only
#   TEAM    $79/mo  · 1 business · 250 credits · calls + research + priority
#   STUDIO  $199/mo · 2 businesses · 600 shared credits · custom domain + analytics
#   AGENCY  $499/mo · 8 businesses · 2000 shared credits · white-label + team seats
STRIPE_PRICE_SOLO="price_..."
STRIPE_PRICE_TEAM="price_..."
STRIPE_PRICE_STUDIO="price_..."
STRIPE_PRICE_AGENCY="price_..."

# =============================================================
# TWILIO (phone + SMS)
# =============================================================
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN=""
TWILIO_API_KEY="SK..."
TWILIO_API_SECRET=""
TWILIO_MESSAGING_SERVICE_SID="MG..."
TWILIO_PHONE_NUMBER_POOL=""

# =============================================================
# VAPI (voice AI)
# =============================================================
VAPI_API_KEY=""
VAPI_ASSISTANT_TEMPLATE_ID=""
VAPI_WEBHOOK_SECRET=""

# =============================================================
# ANTHROPIC (LLM)
# =============================================================
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL_OPUS="claude-opus-4-7"
ANTHROPIC_MODEL_SONNET="claude-sonnet-4-6"
ANTHROPIC_MODEL_HAIKU="claude-haiku-4-5"

# =============================================================
# REPLICATE (image generation — Echo hero photos + brand-kit covers)
# =============================================================
REPLICATE_API_TOKEN="r8_..."

# =============================================================
# META (Instagram + Facebook)
# =============================================================
META_APP_ID=""
META_APP_SECRET=""
NEXT_PUBLIC_META_APP_ID="${META_APP_ID}"
EXPO_PUBLIC_META_APP_ID="${META_APP_ID}"
# The verify token must match what's set on every Meta App webhook
# product subscription. Rotating one without rotating the other
# silently kills inbound delivery — Meta caches "previously verified"
# state and stops sending events without raising an error.
META_WEBHOOK_VERIFY_TOKEN=""
META_WEBHOOK_APP_SECRET="${META_APP_SECRET}"

# =============================================================
# TELEGRAM (Bot API)
# =============================================================
# Random string used as both the URL path-segment secret and the
# X-Telegram-Bot-Api-Secret-Token header value when registering webhooks.
TELEGRAM_WEBHOOK_SECRET=""

# =============================================================
# SENDGRID (transactional + admin alerts + newsletter sends)
# Used for: admin error reports (notifyAdminOfError), magic-link
# fallbacks, brand-driven newsletter sends to subscriber lists.
# =============================================================
SENDGRID_API_KEY="SG...."
# Sender address used for newsletter sends + admin reports. Must be a
# verified sender on the SendGrid account.
NEWSLETTER_FROM_EMAIL="hello@adfi.ca"

# =============================================================
# REMOTION LAMBDA (motion-reel video rendering)
# Rendering happens on AWS Lambda, not Vercel. One-time setup:
#   docs/MOTION_REEL_DEPLOY.md
# After running `npx remotion lambda functions deploy` and
# `npx remotion lambda sites create` you'll have the function name
# and site URL — paste them here.
# =============================================================
REMOTION_AWS_REGION="us-east-1"
REMOTION_LAMBDA_FUNCTION_NAME="remotion-render-4-0-454-mem2048mb-disk2048mb-120sec"
REMOTION_LAMBDA_SITE_URL="https://remotionlambda-useast1-XXXX.s3.us-east-1.amazonaws.com/sites/adfi-motion/index.html"
# IAM user credentials with permissions to invoke the Remotion Lambda
# function + read/write the site bucket. Same user can be reused for
# CLI deploys + runtime invocation. See docs/MOTION_REEL_DEPLOY.md
# for the exact policy.
REMOTION_AWS_ACCESS_KEY_ID=""
REMOTION_AWS_SECRET_ACCESS_KEY=""

# =============================================================
# APP URLS
# NEXT_PUBLIC_WEB_URL is the canonical name. _SITE_URL and _APP_URL
# are accepted as forward-compat aliases by code that reads the
# public base — keep one of them set; setting all three is fine but
# only NEXT_PUBLIC_WEB_URL is actively read by everything new.
# =============================================================
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="${NEXT_PUBLIC_WEB_URL}"
NEXT_PUBLIC_APP_URL="${NEXT_PUBLIC_WEB_URL}"
NEXT_PUBLIC_APP_SCHEME="orb://"
ADMIN_URL="http://localhost:3001"

# =============================================================
# OBSERVABILITY
# =============================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN="${SENTRY_DSN}"
EXPO_PUBLIC_SENTRY_DSN="${SENTRY_DSN}"
SENTRY_AUTH_TOKEN=""
POSTHOG_API_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"

# =============================================================
# ENCRYPTION + SECURITY
# =============================================================
# Used to encrypt OAuth tokens (Meta + Telegram + future) at rest.
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=""

# Salt for hashing visitor IPs in the public onboarding-preview
# rate-limiter. Doesn't need to be high-entropy — it just makes the
# stored hash unique to this deployment. Generate: openssl rand -hex 16
PREVIEW_IP_SALT=""

# =============================================================
# CRON (required for /api/cron/* endpoints — generates Echo/Pulse/Scout
# runs for all eligible users). Generate: openssl rand -hex 32
# Vercel Cron sends this automatically as Authorization: Bearer <secret>
# when the crons array in vercel.json points at these routes.
# =============================================================
CRON_SECRET=""

# =============================================================
# ADMIN ACCESS
# Comma-separated list of emails allowed to access /dashboard in
# apps/admin AND to receive notifyAdminOfError reports (urgent
# third-party outage alerts, billing failures, etc.). Users signed
# in with these emails pass the admin gate without needing
# app_metadata.role = "admin" set in Supabase.
# =============================================================
ADMIN_EMAILS="you@example.com,cofounder@example.com"

# =============================================================
# FEATURE FLAGS
# =============================================================
# Gate the make-video button on draft cards. Off by default until
# the Remotion Lambda function is deployed + env vars above are set.
NEXT_PUBLIC_MOTION_REEL_ENABLED="false"

# =============================================================
# DEV-ONLY (optional)
# =============================================================
LOG_LEVEL="debug"
# DISABLE_WEBHOOKS=1
# MOCK_LLM=1
