{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/trpc/[trpc]/route.ts": { "memory": 2048, "maxDuration": 300 },
    "app/api/cron/daily-content/route.ts": { "memory": 2048, "maxDuration": 300 },
    "app/api/cron/daily-pulse/route.ts": { "memory": 2048, "maxDuration": 300 },
    "app/api/cron/weekly-scout/route.ts": { "memory": 2048, "maxDuration": 300 },
    "app/api/cron/quarterly-strategist/route.ts": { "memory": 2048, "maxDuration": 300 },
    "app/api/upload/logo/route.ts": { "memory": 2048, "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/cron/daily-content",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/daily-pulse",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/weekly-scout",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/quarterly-strategist",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/health",
      "schedule": "0 0 * * *"
    }
  ]
}
